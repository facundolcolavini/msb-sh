{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    
    "baseUrl": ".",
    /* alias */
    "paths": {
      "@/*": ["src/*"],
      "@scripts/*": ["src/scripts/*"],
    }
    
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.astro",
    "src/**/*.tsx",
  ]

}