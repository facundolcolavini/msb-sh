{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "moduleResolution": "node",
    "resolveJsonModule": true,
    /* alias */
    "baseUrl": ".",
    "paths": {
      "@/*" : ["./src/*"],
    }
  },
  "include": [
    "./src/**/*.d.ts",
    "./src/**/*.ts",
    "./src/**/*.astro",
    "./src/**/*.tsx",
  ]

}