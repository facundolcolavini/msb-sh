{
  "compilerOptions": {
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "@/*":[
        "./src/*"
      ]
    }
  },
  "extends": "astro/tsconfigs/strict",
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.astro",
    "src/**/*.tsx",
  ]
}