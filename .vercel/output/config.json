{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/404\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/destacados\\.json\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/results\\.json\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/selects\\.json\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/administracion\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		},
		{
			"src": "^\\/contacto\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/resultados\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/resultados-de-busqueda\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/tasaciones\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/sumate\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "/.*",
			"dest": "_render",
			"status": 404
		}
	]
}