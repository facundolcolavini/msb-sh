---
import ButtonLink from "src/components/ButtonLink.astro";
import HeroContainer from "src/components/HeroContainer.astro";
import SliderA from "src/components/SliderA.astro";
import TitleSections from "src/components/TitleSections.astro";
import BannerSlider from "src/components/preact/BannerSlider";
import HomeLocation from "src/components/preact/Icons/HomeLocation";
import HomeMortgageIcon from "src/components/preact/Icons/HomeMortgageIcon";
import PaperTipsIcon from "src/components/preact/Icons/PaperTipsIcon";
import SearchHome from "src/components/preact/Search/SearchHome";
import Button from "src/components/preact/ui/Buttons/Button";
import CardBranch from "src/components/preact/ui/Cards/CardBranch";
import CardEntrepreneurship from "src/components/preact/ui/Cards/CardEntrepreneurship";
import CardProperty from "src/components/preact/ui/Cards/CardProperty";
import type { APIResponseEntrepreneurship, Results, EntrePreneurShip } from "src/interfaces/entrepreneurship.interfaces";
import type { APIResponseResultsRecords, File } from "src/interfaces/results.records.interfaces";
import type { ResultLocation ,Results as ResultSelects} from "src/interfaces/selects.form.interfaces";
import Layout from "src/layouts/Layout.astro";
import { getAllSelects, getLocations } from "src/services/get-selects-form";
import { fetchData } from "src/utils/fetch-data";



const { resultado } = (await fetchData(
  "fichas.destacadas",
)) as APIResponseResultsRecords;
const { resultado: resEmprendimientos } = (await fetchData(
  "resultados.emprendimientos",
)) as APIResponseEntrepreneurship;
const { emprendimiento: entrepreneurship, img } = resEmprendimientos;
const { fichas } = resultado;
const cardData: File[] = fichas as File[]; // Update the type of cardData
const titlePage = "Home";
const description =
  "Propiedades en alquiler y venta - Matías Szpira Bienes Raíces";

const selects = (await getAllSelects()) as ResultSelects;
const locations = (await getLocations()) as ResultLocation;
 
---

<Layout title={titlePage} , description={description}>
  <HeroContainer img="/images/background-hero.webp">
    <div
      class="absolute inset-0 flex flex-col justify-between items-center w-100 mx-auto container"
    >
      <div class="bg-[#D9D9D9] bg-opacity-40 py-6 min-w-full mt-8">
        <h1
          style={{ textShadow: "0px 4px 4px rgba(0, 0, 0, 0.50);" }}
          class="text-white text-4xl md:text-5xl lg:text-6xl font-base font-semibold font-cormorant text-pretty lg:drop-shadow-2xl text-center"
        >
          BUENA <span class="text-primary-text-msb"> GENTE</span>. BUENAS <span
            class="text-primary-text-msb">RAÍCES</span
          >. BUENOS <span class="text-primary-text-msb">NEGOCIOS</span>
        </h1>
      </div>
      <!-- Agrega aquí tu buscador -->

      <SearchHome client:load selects={selects} locations={locations} client:load />

      <div></div>
    </div>
  </HeroContainer>
  <section class="bg-secondary-bg-msb">
    <div class="container mx-auto px-3 md:px-0 lg:px-0">
      <div class="grid lg:grid-cols-3 ms:px-3 gap-2 py-20">
        <ButtonLink href="/sumate">
          <Button
            variant="outline"
            addStyles="rounded-lg shadow-lg w-full h-full"
          >
            <div
              class="inline-flex lg:justify-center items-center w-full gap-3 py-5"
            >
              <div class="rounded-full p-2 bg-[#D9D9D9]">
                <HomeMortgageIcon
                  addStyles="object-contain bg-gradient-primary-msb "
                  w="42"
                  h="40"
                />
              </div>
              <div class="flex flex-col gap-2 items-stretch">
                <h1
                  class="text-base font-semibold text-primary-text-msb text-left"
                >
                  ¿Qué necesito para comprar?
                </h1>
                <p class="text-primary-text-msb text-left font-normal">
                  Conocé los requisitos para comprar una propiedad
                </p>
              </div>
            </div>
          </Button>
        </ButtonLink>
        <ButtonLink href="/sumate">
          <Button
            variant="outline"
            addStyles="rounded-lg shadow-lg w-full h-full"
          >
            <div
              class="inline-flex lg:justify-center items-center w-full gap-3 py-5"
            >
              <div class="rounded-full p-2 bg-[#D9D9D9]">
                <HomeLocation
                  addStyles="object-contain bg-gradient-primary-msb "
                  w="42"
                  h="40"
                />
              </div>
              <div class="flex flex-col gap-2 items-stretch">
                <h1
                  class="text-base font-semibold text-primary-text-msb text-left"
                >
                  Guía de Barrios
                </h1>
                <p class="text-primary-text-msb text-left font-normal">
                  Conocé los barrios y elegí tu zona ideal
                </p>
              </div>
            </div>
          </Button>
        </ButtonLink>
        <ButtonLink href="/sumate">
          <Button
            variant="outline"
            addStyles="rounded-lg shadow-lg w-full h-full"
          >
            <div
              class="inline-flex lg:justify-center items-center w-full gap-3 py-5"
            >
              <div class="rounded-full p-2 bg-[#D9D9D9]">
                <PaperTipsIcon
                  addStyles="object-contain bg-gradient-primary-msb "
                  w="42"
                  h="40"
                />
              </div>
              <div class="flex flex-col gap-2 items-stretch">
                <h1
                  class="text-base font-semibold text-primary-text-msb text-left"
                >
                  Tips de Mudanza
                </h1>
                <p class="text-primary-text-msb text-left font-normal">
                  Guía para mudarte sin estrés, de forma rápida y eficiente
                </p>
              </div>
            </div>
          </Button>
        </ButtonLink>
      </div>
    </div>
  </section>
  <section class="bg-primary-msb">
    <div class="container mx-auto px-3 md:px-0 lg:px-0 py-20">
      <TitleSections
        class="text-white text-6xl md:text-7xl lg:text-8xl font-base font-medium font-cormorant text-pretty text-center"
      >
        Propiedades Destacadas
      </TitleSections>
      <p
        class="text-white text-center text-md md:text-lg lg:text-2xl font-light py-5"
      >
        La mejor selección de inmuebles en las zonas que estás buscando.
      </p>

      <SliderA colsNr={3} height={10} width={10} classSlide="slider1">
        {
          cardData.map((card) => (
            <CardProperty
              key="unique-key"
              href="/propiedades"
              addStyles={"w-full h-full card"}
              cardData={card as File}
            />
          ))
        }
      </SliderA>
    </div>
  </section>
  <section class="bg-secondary-bg-msb px-3 md:px-0 lg:px-0 py-20">
    <div
      class="container mx-auto grid grid-col lg:grid-cols-2 justify-center place-content-center rounded-md border-primary-border-msb border-2 h-100 py-20"
    >
      <div class="flex justify-end gap-10 flex-col self-center lg:px-20 p-6">
        <TitleSections
          class="text-center md:text-centter lg:text-start text-secondary-text-msb text-4xl"
        >
          Nuestros Emprendimientos
        </TitleSections>
        <p
          class="font-medium text-secondary-text-msb text-center md:text-center lg:text-start text-lg"
        >
          Invertí en bienes raíces, nosotros te asesoramos
        </p>
        <ButtonLink
          href="/emprendimientos"
          class="flex justify-center md:justify-center w-100 p-0 lg:w-fit lg:justify-start text-pretty"
        >
          <Button
            variant="outline"
            addStyles="bg-secondary-bg-msb px-0 md:px-0 lg:px-20 text-lg rounded-lg shadow-lg text-nowrap  w-full h-full"
          >
            Me interesa
          </Button>
        </ButtonLink>
      </div>
      <div class="grid space-y-4">
        <div
          class="grid grid-cols-1 w-full md:grid-cols-3 lg:grid-cols-3 justify-between gap-4 p-6 lg:px-2 md:px-6"
        >
          <ButtonLink href="/emprendimientos/pozo">
            <Button
              variant="primary"
              addStyles="rounded-md  shadow-lg w-full h-full py-3 active:bg-primary-bg-msb text-pretty"
            >
              En Pozo
            </Button>
          </ButtonLink>
          <ButtonLink href="/emprendimientos/construcción">
            <Button
              variant="primary"
              addStyles="rounded-md shadow-lg  w-full h-full text-pretty"
            >
              En Construcción
            </Button>
          </ButtonLink>
          <ButtonLink href="/emprendimientos/terminado">
            <Button
              variant="primary"
              addStyles="rounded-md shadow-lg w-full h-full  "
            >
              Terminado
            </Button>
          </ButtonLink>
        </div>
        <!-- Slider de emprendimientos -->
        <SliderA colsNr={2} height={10} width={10} classSlide="slider2">
          {
            entrepreneurship.map(
              ({ ed_nom, ed_pos, img_princ, ed_est, ed_idl }: EntrePreneurShip) => (
                <CardEntrepreneurship
                  href={`/emprendimientos/${ed_idl}`}
                  addStyles={"card"}
                  cardData={{
                    ed_nom,
                    ed_pos,
                    img_princ,
                    ed_est,
                  }}
                />
              ),
            )
          }
        </SliderA>
      </div>
    </div>
  </section>
  <section class="bg-[#8D8777] py-10" transition:animate={"fade"}>
    <BannerSlider slides={img[3]} sliderTime={8000} client:visible>
      <div
        class="grid align-end h-full items-center justify-center lg:justify-end self-end place-content-center text-center lg:text-start container mx-auto relative z-1"
      >
        <TitleSections
          class="text-white text-6xl md:text-7xl lg:text-8xl font-base font-medium font-cormorant text-pretty md:text-center lg:text-start"
        >
          Tasaciones
        </TitleSections>
        <p
          class="text-white text-lg md:text-xl lg:text-2xl font-normal font-open-sans self-start"
        >
          Tu descripción o contenido del párrafo aquí.
        </p>
        <ButtonLink
          href="/tasaciones"
          class="flex justify-center lg:items-end p-0 mt-4 lg:w-fit lg:self-start"
        >
          <Button
            variant="outline"
            addStyles="bg-secondary-bg-msb px-0 md:px-0 lg:px-20 text-lg rounded-lg shadow-lg text-nowrap  w-full h-full"
          >
            Tasar
          </Button>
        </ButtonLink>
      </div>
    </BannerSlider>
  </section>
  <section class="bg-secondary-bg-msb py-20" transition:animate="fade">
    <div>
      <TitleSections
        class="text-primary-text-msb text-6xl md:text-7xl lg:text-8xl font-base font-medium font-cormorant text-pretty text-center"
      >
        Nuestras Sucursales
      </TitleSections>
      <p
        class="text-secondary-text-msb text-center text-md md:text-lg lg:text-2xl font-light py-5"
      >
        Elegí tu sucursal más cercana
      </p>
    </div>
    <div
      class="grid grid-cols justify-center md:grid-cols-2 gap-5 lg:gap-2 lg:grid-cols-4 container mx-auto"
    >
      <CardBranch
        href="https://maps.app.goo.gl/tctkkMnT39ZuecvY6"
        suc_name="Belgrano"
        suc_loc="Capital Federal"
        suc_img="/images/sucursal-belgrano.webp"
        suc_dir="Av. Juramento 1475, Piso 3 Of. 4"
        suc_phone="112461-0859"
        addStyles={"hover:border-primary-border-msb hover:border-4 h-100 transition duration-500 ease-in-out easy-out transform hover:-translate-y-1"}
      />
      <CardBranch
        href="https://maps.app.goo.gl/PdCXedJ3XriKhkeD6"
        suc_name="Castelar"
        suc_loc="Casa Central"
        suc_img="/images/sucursal-castelar.webp"
        suc_dir="Avellaneda 976, Castelar"
        suc_phone="4627-8034 / 7548-6846"
        addStyles={"hover:border-primary-border-msb hover:border-4 h-100 transition duration-500 ease-in-out easy-out transform hover:-translate-y-1"}
      />
      <CardBranch
        href="https://maps.app.goo.gl/Fo5cNCeaXJSRbkEz7"
        suc_name="Fco. Álvarez"
        suc_loc="Colectora Sur Acceso Oeste"
        suc_img="/images/sucursal-fco-alvarez.webp"
        suc_dir="K41 Piso 3, Of. 327"
        suc_phone="2130-9600 / 112364-4767"
        addStyles={"hover:border-primary-border-msb hover:border-4 h-100 transition duration-500 ease-in-out easy-out transform hover:-translate-y-1"}
      />
      <CardBranch
        href="https://maps.app.goo.gl/GgiKgSmGr31CvVXw5"
        suc_name="Parque Leloir"
        suc_loc="Complejo Acorus"
        suc_img="/images/sucursal-parque-leloir.webp"
        suc_dir="Martín Fierro 2921, Piso 2 Of. 201"
        suc_phone="4627-8034 / 7548-6846"
        addStyles={"hover:border-primary-border-msb hover:border-4 h-100 transition duration-500 ease-in-out easy-out transform hover:-translate-y-1"}
      />
    </div>
  </section>
</Layout>
